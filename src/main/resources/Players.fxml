<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<BorderPane fx:controller="org.example.controller.PlayersController"
            prefHeight="650.0" prefWidth="900.0"
            maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1">

    <left>
        <VBox prefWidth="165.0" spacing="20.0" style="-fx-background-color: #02182e;" BorderPane.alignment="CENTER">
            <children>
                <Label prefHeight="41.0" prefWidth="130.0" text=" E-Sportify" textFill="#d3e2e7">
                    <font><Font name="Century Schoolbook Bold" size="16.0"/></font>
                </Label>

                <Button onAction="#goToDashboard" prefHeight="30.0" prefWidth="132.0"
                        style="-fx-background-color: #02182e;" text=" Dashboard" textFill="WHITE">
                    <graphic><ImageView fitHeight="22.0" fitWidth="16.0" preserveRatio="true"><image><Image url="@images/progress.png"/></image></ImageView></graphic>
                </Button>

                <Button onAction="#goToPlayers" prefHeight="34.0" prefWidth="140.0"
                        style="-fx-background-color: #0b345c; -fx-background-radius: 14;"
                        text=" Players" textFill="WHITE">
                    <graphic><ImageView fitHeight="17.0" fitWidth="25.0" preserveRatio="true"><image><Image url="@images/soccer-player.png"/></image></ImageView></graphic>
                </Button>

                <Button onAction="#goToTeams" prefHeight="30.0" prefWidth="132.0"
                        style="-fx-background-color: #02182e;" text=" Teams" textFill="WHITE">
                    <graphic><ImageView fitHeight="20.0" fitWidth="25.0" preserveRatio="true"><image><Image url="@images/team.png"/></image></ImageView></graphic>
                </Button>

                <Button onAction="#goToTournaments" prefHeight="30.0" prefWidth="140.0"
                        style="-fx-background-color: #02182e;" text=" Tournaments" textFill="WHITE">
                    <graphic><ImageView fitHeight="21.0" fitWidth="27.0" preserveRatio="true"><image><Image url="@images/team-building.png"/></image></ImageView></graphic>
                </Button>

                <Button onAction="#goToMatches" prefHeight="30.0" prefWidth="132.0"
                        style="-fx-background-color: #02182e;" text=" Matches" textFill="WHITE">
                    <graphic><ImageView fitHeight="26.0" fitWidth="26.0" preserveRatio="true"><image><Image url="@images/match (1).png"/></image></ImageView></graphic>
                </Button>

                <Button onAction="#goToGames" prefHeight="30.0" prefWidth="132.0"
                        style="-fx-background-color: #02182e;" text=" Games" textFill="WHITE">
                    <graphic><ImageView fitHeight="30.0" fitWidth="28.0" preserveRatio="true"><image><Image url="@images/game-controller.png"/></image></ImageView></graphic>
                </Button>

                <Button onAction="#goToSeasons" prefHeight="30.0" prefWidth="132.0"
                        style="-fx-background-color: #02182e;" text=" Seasons" textFill="WHITE">
                    <graphic><ImageView fitHeight="30.0" fitWidth="22.0" preserveRatio="true"><image><Image url="@images/calendar.png"/></image></ImageView></graphic>
                </Button>

                <Pane VBox.vgrow="ALWAYS"/>

                <Button onAction="#logout" prefHeight="30.0" prefWidth="132.0"
                        style="-fx-background-color: #02182e;" text=" LogOut" textFill="WHITE">
                    <graphic><ImageView fitHeight="19.0" fitWidth="25.0" preserveRatio="true"><image><Image url="@images/logout.png"/></image></ImageView></graphic>
                </Button>
            </children>
            <padding><Insets top="18.0" left="20.0" right="5.0" bottom="18.0"/></padding>
        </VBox>
    </left>

    <center>
        <VBox spacing="15.0" style="-fx-background-color: #02182e;">
            <padding><Insets top="20.0" right="22.0" bottom="20.0" left="24.0"/></padding>

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" minHeight="88.0" prefHeight="88.0" maxHeight="88.0"
                  spacing="16.0" style="-fx-background-color: #022c50; -fx-background-radius: 24; -fx-padding: 14 20;">
                <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                    <Label text="Players" textFill="#d3e2e7">
                        <font><Font name="Segoe UI Bold" size="31.0"/></font>
                    </Label>
                    <Label text="View player ranks, teams, achievements, and top competitors" textFill="#a9bdc7">
                        <font><Font name="Segoe UI" size="13.0"/></font>
                    </Label>
                </VBox>
                <ImageView fitHeight="54.0" fitWidth="54.0" preserveRatio="true">
                    <image><Image url="@images/soccer-player.png"/></image>
                </ImageView>
            </HBox>

            <!-- One clean summary strip instead of crowded cards -->
            <HBox alignment="CENTER_LEFT" spacing="18.0"
                  minHeight="76.0" prefHeight="76.0" maxHeight="76.0"
                  style="-fx-background-color: #2b537e; -fx-background-radius: 22; -fx-padding: 14 20;">
                <Label text="Top Player" textFill="#d3e2e7">
                    <font><Font name="Segoe UI Bold" size="17.0"/></font>
                </Label>

                <VBox spacing="1.0" HBox.hgrow="ALWAYS">
                    <Label fx:id="topPlayerNameLabel" text="Player Name" textFill="WHITE">
                        <font><Font name="Segoe UI Bold" size="22.0"/></font>
                    </Label>
                    <Label fx:id="topPlayerInfoLabel" text="Team | points | achievement" textFill="#d3e2e7"/>
                </VBox>

                <VBox alignment="CENTER" spacing="1.0" minWidth="85.0" prefWidth="85.0">
                    <Label text="Rank" textFill="#d3e2e7"/>
                    <Label fx:id="topPlayerRankLabel" text="#-" textFill="WHITE">
                        <font><Font name="Segoe UI Bold" size="23.0"/></font>
                    </Label>
                </VBox>

                <Button onAction="#openTopPlayer" prefHeight="34.0" prefWidth="82.0" text="Open" textFill="WHITE"
                        style="-fx-background-color: #8197ac; -fx-background-radius: 17;"/>
            </HBox>

            <HBox spacing="17.0" VBox.vgrow="ALWAYS">
                <VBox spacing="11.0" minWidth="294.0" prefWidth="294.0" maxWidth="294.0"
                      style="-fx-background-color: #5f86a6; -fx-background-radius: 24; -fx-padding: 18;">
                    <Label text="Featured Player" textFill="WHITE">
                        <font><Font name="Segoe UI Bold" size="23.0"/></font>
                    </Label>
                    <Line endX="254.0" opacity="0.55" stroke="WHITE"/>

                    <VBox alignment="CENTER" spacing="7.0" minHeight="116.0" prefHeight="116.0"
                          style="-fx-background-color: #022c50; -fx-background-radius: 18;">
                        <ImageView fitHeight="56.0" fitWidth="56.0" preserveRatio="true">
                            <image><Image url="@images/soccer-player.png"/></image>
                        </ImageView>
                        <Label fx:id="featuredPlayerNameLabel" text="Player Name" textFill="WHITE">
                            <font><Font name="Segoe UI Bold" size="21.0"/></font>
                        </Label>
                    </VBox>

                    <Label fx:id="featuredPlayerEmailLabel" text="Email: -" textFill="WHITE"/>
                    <Label fx:id="featuredPlayerJoinDateLabel" text="Join Date: -" textFill="WHITE"/>
                    <Label fx:id="featuredPlayerTeamLabel" text="Team: -" textFill="WHITE"/>
                    <Label fx:id="featuredPlayerAchievementLabel" text="Achievement: -" textFill="WHITE"/>

                    <Pane VBox.vgrow="ALWAYS"/>

                    <Button onAction="#viewFeaturedPlayerDetails" prefHeight="36.0" prefWidth="250.0" text="View Player Details" textFill="WHITE"
                            style="-fx-background-color: #02182e; -fx-background-radius: 18;"/>
                </VBox>

                <VBox spacing="10.0" minWidth="377.0" prefWidth="377.0" maxWidth="377.0"
                      style="-fx-background-color: #022c50; -fx-background-radius: 24; -fx-padding: 18;">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Top Ranked Players" textFill="WHITE">
                            <font><Font name="Segoe UI Bold" size="23.0"/></font>
                        </Label>
                        <Pane HBox.hgrow="ALWAYS"/>
                        <Button onAction="#filterPlayers" prefHeight="30.0" prefWidth="74.0" text="Filter" textFill="WHITE"
                                style="-fx-background-color: #2b537e; -fx-background-radius: 15;"/>
                    </HBox>
                    <Line endX="336.0" opacity="0.45" stroke="#d3e2e7"/>

                    <HBox alignment="CENTER_LEFT" spacing="12.0" minHeight="55.0" prefHeight="55.0"
                          style="-fx-background-color: #2b537e; -fx-background-radius: 16; -fx-padding: 10 13;">
                        <Label fx:id="rank1Label" text="#1" textFill="WHITE">
                            <font><Font name="Segoe UI Bold" size="16.0"/></font>
                        </Label>
                        <VBox HBox.hgrow="ALWAYS">
                            <Label fx:id="player1NameLabel" text="Player 1" textFill="WHITE">
                                <font><Font name="Segoe UI Bold" size="16.0"/></font>
                            </Label>
                            <Label fx:id="player1InfoLabel" text="Team | points | achievement" textFill="#d3e2e7"/>
                        </VBox>
                        <Button onAction="#openPlayerRow1" prefHeight="30.0" prefWidth="68.0" text="Open" textFill="WHITE"
                                style="-fx-background-color: #8197ac; -fx-background-radius: 15;"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="12.0" minHeight="55.0" prefHeight="55.0"
                          style="-fx-background-color: #1d4052; -fx-background-radius: 16; -fx-padding: 10 13;">
                        <Label fx:id="rank2Label" text="#2" textFill="WHITE">
                            <font><Font name="Segoe UI Bold" size="16.0"/></font>
                        </Label>
                        <VBox HBox.hgrow="ALWAYS">
                            <Label fx:id="player2NameLabel" text="Player 2" textFill="WHITE">
                                <font><Font name="Segoe UI Bold" size="16.0"/></font>
                            </Label>
                            <Label fx:id="player2InfoLabel" text="Team | points | achievement" textFill="#d3e2e7"/>
                        </VBox>
                        <Button onAction="#openPlayerRow2" prefHeight="30.0" prefWidth="68.0" text="Open" textFill="WHITE"
                                style="-fx-background-color: #8197ac; -fx-background-radius: 15;"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="12.0" minHeight="55.0" prefHeight="55.0"
                          style="-fx-background-color: #1d4052; -fx-background-radius: 16; -fx-padding: 10 13;">
                        <Label fx:id="rank3Label" text="#3" textFill="WHITE">
                            <font><Font name="Segoe UI Bold" size="16.0"/></font>
                        </Label>
                        <VBox HBox.hgrow="ALWAYS">
                            <Label fx:id="player3NameLabel" text="Player 3" textFill="WHITE">
                                <font><Font name="Segoe UI Bold" size="16.0"/></font>
                            </Label>
                            <Label fx:id="player3InfoLabel" text="Team | points | achievement" textFill="#d3e2e7"/>
                        </VBox>
                        <Button onAction="#openPlayerRow3" prefHeight="30.0" prefWidth="68.0" text="Open" textFill="WHITE"
                                style="-fx-background-color: #8197ac; -fx-background-radius: 15;"/>
                    </HBox>

                    <HBox alignment="CENTER_LEFT" spacing="12.0" minHeight="55.0" prefHeight="55.0"
                          style="-fx-background-color: #1d4052; -fx-background-radius: 16; -fx-padding: 10 13;">
                        <Label fx:id="rank4Label" text="#4" textFill="WHITE">
                            <font><Font name="Segoe UI Bold" size="16.0"/></font>
                        </Label>
                        <VBox HBox.hgrow="ALWAYS">
                            <Label fx:id="player4NameLabel" text="Player 4" textFill="WHITE">
                                <font><Font name="Segoe UI Bold" size="16.0"/></font>
                            </Label>
                            <Label fx:id="player4InfoLabel" text="Team | points | achievement" textFill="#d3e2e7"/>
                        </VBox>
                        <Button onAction="#openPlayerRow4" prefHeight="30.0" prefWidth="68.0" text="Open" textFill="WHITE"
                                style="-fx-background-color: #8197ac; -fx-background-radius: 15;"/>
                    </HBox>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>