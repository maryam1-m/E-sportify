<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Rectangle2D?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.ColorAdjust?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<BorderPane fx:controller="org.example.controller.DashboardController"
            prefHeight="650.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1">

    <left>
        <VBox spacing="20.0" style="-fx-background-color: #02182e;" BorderPane.alignment="CENTER">
            <children>

                <Label prefHeight="41.0" prefWidth="113.0" text="   E-Sportify" textFill="#d3e2e7">
                    <font>
                        <Font name="Century Schoolbook Bold" size="16.0"/>
                    </font>
                </Label>

                <Button onAction="#goToDashboard"
                        mnemonicParsing="false"
                        prefHeight="26.0"
                        prefWidth="126.0"
                        style="-fx-background-color: #02182e;"
                        text="     Dashboard"
                        textFill="WHITE">

                    <graphic>
                        <ImageView fitHeight="22.0"
                                   fitWidth="16.0"
                                   pickOnBounds="true"
                                   preserveRatio="true">

                            <image>
                                <Image url="@images/progress.png"/>
                            </image>

                        </ImageView>
                    </graphic>

                </Button>

                <Button onAction="#goToPlayers" mnemonicParsing="false" prefHeight="26.0" prefWidth="107.0"
                        style="-fx-background-color: #02182e;" text="        Players" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="17.0" fitWidth="39.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@images/soccer-player.png"/></image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToTeams" mnemonicParsing="false" prefHeight="28.0" prefWidth="106.0"
                        style="-fx-background-color: #02182e;" text="         Teams" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="20.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@images/team.png"/></image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToTournaments" mnemonicParsing="false" prefHeight="26.0" prefWidth="132.0"
                        style="-fx-background-color: #02182e;" text="     Tournments " textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="21.0" fitWidth="27.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@images/team-building.png"/></image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToMatches" mnemonicParsing="false" prefHeight="30.0" prefWidth="110.0"
                        style="-fx-background-color: #02182e;" text="    Matches" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="26.0" fitWidth="26.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@images/match (1).png"/></image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToGames" mnemonicParsing="false" prefHeight="30.0" prefWidth="101.0"
                        style="-fx-background-color: #02182e;" text="    Games" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="32.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@images/game-controller.png"/></image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToSeasons" mnemonicParsing="false" prefHeight="30.0" prefWidth="111.0"
                        style="-fx-background-color: #02182e;" text="     Seasons" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="32.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@images/calendar.png"/></image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#logout" mnemonicParsing="false" prefHeight="30.0" prefWidth="111.0"
                        style="-fx-background-color: #02182e;" text="      LogOut" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="19.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                            <image><Image url="@images/logout.png"/></image>
                        </ImageView>
                    </graphic>
                </Button>

            </children>
            <padding>
                <Insets left="20.0"/>
            </padding>
            <effect>
                <ColorAdjust/>
            </effect>
        </VBox>
    </left>

    <center>
        <VBox alignment="TOP_CENTER" spacing="22.0"
              style="-fx-background-color: #02182e;">
            <padding>
                <Insets top="40.0" left="35.0" right="35.0" bottom="35.0"/>
            </padding>

            <Label text="Players Overview" textFill="#d3e2e7">
                <font>
                    <Font name="Segoe UI Bold" size="27.0"/>
                </font>
            </Label>

            <Label text="Best ranked players in E-Sportify"
                   textFill="#bcd4dc">
                <font>
                    <Font name="Segoe UI" size="15.0"/>
                </font>
            </Label>

            <!-- هون ممكن تحطي صورة صغيرة للـ Players -->

            <VBox prefWidth="500.0" spacing="12.0"
                  style="-fx-background-color: #022c50; -fx-background-radius: 24; -fx-padding: 22;">

                <Label text="Top Players" textFill="WHITE">
                    <font>
                        <Font name="Segoe UI Bold" size="22.0"/>
                    </font>
                </Label>

                <Line endX="455.0" opacity="0.35" stroke="#d3e2e7"/>

                <Label text="1. Ahmad Ali           Team Lions        950 pts" textFill="WHITE"/>
                <Label text="2. Maryam Abdoh        Shadow Wolves     870 pts" textFill="WHITE"/>
                <Label text="3. Jana Salahat        Apex Squad        820 pts" textFill="WHITE"/>
                <Label text="4. Yamen Marie         The Titans        760 pts" textFill="WHITE"/>
                <Label text="5. Ali Mabrouk         Iron Brokers      700 pts" textFill="WHITE"/>
                <Label text="6. Saif Mohammad       Nexus Squad       650 pts" textFill="WHITE"/>

            </VBox>
        </VBox>
    </center>

</BorderPane>