<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Rectangle2D?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.effect.Blend?>
<?import javafx.scene.effect.ColorAdjust?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<BorderPane fx:controller="org.example.controller.DashboardController"
            maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="650.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1">

    <!-- ================= LEFT SIDEBAR - same dashboard style ================= -->
    <left>
        <VBox spacing="20.0" style="-fx-background-color: #02182e;" BorderPane.alignment="CENTER">
            <children>
                <Label prefHeight="41.0" prefWidth="113.0" text="   E-Sportify" textFill="#d3e2e7">
                    <font>
                        <Font name="Century Schoolbook Bold" size="16.0" />
                    </font>
                </Label>

                <Button onAction="#goToDashboard"
                        mnemonicParsing="false"
                        prefHeight="26.0"
                        prefWidth="126.0"
                        style="-fx-background-color: #02182e;"
                        text="     Dashboard"
                        textFill="WHITE">

                    <graphic>
                        <ImageView fitHeight="22.0"
                                   fitWidth="16.0"
                                   pickOnBounds="true"
                                   preserveRatio="true">

                            <image>
                                <Image url="@images/progress.png" />
                            </image>

                        </ImageView>
                    </graphic>

                </Button>

                <Button onAction="#goToPlayers" mnemonicParsing="false" prefHeight="26.0" prefWidth="107.0"
                        style="-fx-background-color: #02182e;" text="        Players" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="17.0" fitWidth="39.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/soccer-player.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToTeams" mnemonicParsing="false" prefHeight="28.0" prefWidth="106.0"
                        style="-fx-background-color: #02182e;" text="         Teams" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="20.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/team.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToTournaments" mnemonicParsing="false" prefHeight="26.0" prefWidth="132.0"
                        style="-fx-background-color: #02182e;" text="     Tournaments" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="21.0" fitWidth="27.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/team-building.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToMatches" mnemonicParsing="false" prefHeight="30.0" prefWidth="110.0"
                        style="-fx-background-color: #02182e;" text="    Matches" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="26.0" fitWidth="26.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/match (1).png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToGames" mnemonicParsing="false" prefHeight="30.0" prefWidth="101.0"
                        style="-fx-background-color: #02182e;" text="    Games" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="32.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/game-controller.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToSeasons" mnemonicParsing="false" prefHeight="30.0" prefWidth="111.0"
                        style="-fx-background-color: #022c50; -fx-background-radius: 12;" text="     Seasons" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="32.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/calendar.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#logout" mnemonicParsing="false" prefHeight="30.0" prefWidth="111.0"
                        style="-fx-background-color: #02182e;" text="      LogOut" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="19.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/logout.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
            </children>

            <padding>
                <Insets left="20.0" />
            </padding>

            <effect>
                <ColorAdjust />
            </effect>
        </VBox>
    </left>

    <!-- ================= CENTER - SEASONS USER SCREEN ================= -->
    <center>
        <VBox alignment="TOP_CENTER" prefHeight="650.0" prefWidth="724.0" spacing="16.0"
              style="-fx-background-color: #02182e;">
            <padding>
                <Insets top="25.0" right="25.0" bottom="22.0" left="25.0" />
            </padding>

            <children>
                <!-- Header -->
                <HBox alignment="CENTER_LEFT" prefHeight="78.0" prefWidth="675.0" spacing="18.0"
                      style="-fx-background-color: #022c50; -fx-background-radius: 22; -fx-padding: 14 20 14 20;">
                    <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Seasons" textFill="#d3e2e7">
                                    <font>
                                        <Font name="Century Schoolbook Bold" size="27.0" />
                                    </font>
                                </Label>
                                <Label text="View active seasons, dates, status, and season tournaments" textFill="#d3e2e7">
                                    <font>
                                        <Font name="Century" size="13.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <!-- هون ممكن تحطي صورة صغيرة للسيزون / calendar hero -->
                        <ImageView fitHeight="52.0" fitWidth="52.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/calendar.png" />
                            </image>
                            <viewport>
                                <Rectangle2D />
                            </viewport>
                        </ImageView>
                    </children>
                </HBox>

                <!-- Summary Cards -->
                <HBox alignment="CENTER" prefHeight="125.0" prefWidth="675.0" spacing="18.0">
                    <children>
                        <VBox alignment="CENTER" prefHeight="112.0" prefWidth="210.0" spacing="6.0"
                              style="-fx-background-color: #2b537e; -fx-background-radius: 28;">
                            <children>
                                <Label text="Current Season" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="18.0" />
                                    </font>
                                </Label>
                                <Line endX="78.0" opacity="0.55" startX="-78.0" stroke="#d3e2e7" />
                                <Label text="Winter 2026" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="25.0" />
                                    </font>
                                </Label>
                                <Label text="Active now" textFill="#d3e2e7" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" prefHeight="112.0" prefWidth="210.0" spacing="6.0"
                              style="-fx-background-color: #1d4052; -fx-background-radius: 28;">
                            <children>
                                <Label text="Season Tournaments" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="18.0" />
                                    </font>
                                    <effect>
                                        <Blend />
                                    </effect>
                                </Label>
                                <Line endX="78.0" opacity="0.55" startX="-78.0" stroke="#d3e2e7" />
                                <Label text="8" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="30.0" />
                                    </font>
                                </Label>
                                <Label text="Open competitions" textFill="#d3e2e7" />
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" prefHeight="112.0" prefWidth="210.0" spacing="6.0"
                              style="-fx-background-color: #8197ac; -fx-background-radius: 28;">
                            <children>
                                <Label text="Registered Teams" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="18.0" />
                                    </font>
                                </Label>
                                <Line endX="78.0" opacity="0.55" startX="-78.0" stroke="#d3e2e7" />
                                <Label text="32" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="30.0" />
                                    </font>
                                </Label>
                                <Label text="Across all games" textFill="WHITE" />
                            </children>
                        </VBox>
                    </children>
                </HBox>

                <!-- Main Content -->
                <HBox alignment="TOP_CENTER" prefHeight="365.0" prefWidth="675.0" spacing="22.0">
                    <children>
                        <!-- Featured Season Card -->
                        <VBox prefHeight="345.0" prefWidth="270.0" spacing="12.0"
                              style="-fx-background-color: #5f86a6; -fx-background-radius: 22; -fx-padding: 18;">
                            <children>
                                <Label text="Featured Season" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="20.0" />
                                    </font>
                                </Label>
                                <Line endX="225.0" opacity="0.3" startX="-18.0" stroke="#d3e2e7" />

                                <!-- هون ممكن تحطي صورة كبيرة للسيزون إذا بدك -->
                                <VBox alignment="CENTER" prefHeight="88.0" prefWidth="230.0"
                                      style="-fx-background-color: #022c50; -fx-background-radius: 18;">
                                    <children>
                                        <ImageView fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
                                            <image>
                                                <Image url="@images/trophy.png" />
                                            </image>
                                        </ImageView>
                                    </children>
                                </VBox>

                                <Label text="Winter Championship" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="18.0" />
                                    </font>
                                </Label>
                                <Label text="Start Date: 01 / 12 / 2026" textFill="WHITE" />
                                <Label text="End Date: 28 / 02 / 2027" textFill="WHITE" />
                                <Label text="Status: Active" textFill="WHITE" />
                                <Label text="Games: Valorant, FIFA, Rocket League" textFill="WHITE" wrapText="true" />

                                <Region VBox.vgrow="ALWAYS" />

                                <Button mnemonicParsing="false" prefHeight="34.0" prefWidth="230.0"
                                        style="-fx-background-color: #02182e; -fx-background-radius: 16;"
                                        text="View Season Details" textFill="WHITE" />
                            </children>
                        </VBox>

                        <!-- Seasons List -->
                        <VBox prefHeight="345.0" prefWidth="380.0" spacing="10.0"
                              style="-fx-background-color: #022c50; -fx-background-radius: 22; -fx-padding: 16;">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="10.0">
                                    <children>
                                        <Label text="Available Seasons" textFill="WHITE" HBox.hgrow="ALWAYS">
                                            <font>
                                                <Font name="ArtifaktElement-Heavy" size="20.0" />
                                            </font>
                                        </Label>
                                        <Button mnemonicParsing="false" prefHeight="28.0" prefWidth="82.0"
                                                style="-fx-background-color: #2b537e; -fx-background-radius: 14;"
                                                text="Filter" textFill="WHITE" />
                                    </children>
                                </HBox>

                                <Line endX="330.0" opacity="0.27" startX="-16.0" stroke="#d3e2e7" />

                                <HBox alignment="CENTER_LEFT" spacing="14.0"
                                      style="-fx-background-color: #1d4052; -fx-background-radius: 15; -fx-padding: 10;">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Winter 2026" textFill="WHITE">
                                                    <font><Font name="ArtifaktElement-Heavy" size="15.0" /></font>
                                                </Label>
                                                <Label text="01 Dec 2026  -  28 Feb 2027" textFill="#d3e2e7" />
                                                <Label text="Status: Active | 8 tournaments" textFill="#d3e2e7" />
                                            </children>
                                        </VBox>
                                        <Button mnemonicParsing="false" prefHeight="28.0" prefWidth="70.0"
                                                style="-fx-background-color: #5f86a6; -fx-background-radius: 12;"
                                                text="Open" textFill="WHITE" />
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="14.0"
                                      style="-fx-background-color: #1d4052; -fx-background-radius: 15; -fx-padding: 10;">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Spring 2027" textFill="WHITE">
                                                    <font><Font name="ArtifaktElement-Heavy" size="15.0" /></font>
                                                </Label>
                                                <Label text="01 Mar 2027  -  31 May 2027" textFill="#d3e2e7" />
                                                <Label text="Status: Upcoming | registration soon" textFill="#d3e2e7" />
                                            </children>
                                        </VBox>
                                        <Button mnemonicParsing="false" prefHeight="28.0" prefWidth="70.0"
                                                style="-fx-background-color: #5f86a6; -fx-background-radius: 12;"
                                                text="Open" textFill="WHITE" />
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="14.0"
                                      style="-fx-background-color: #1d4052; -fx-background-radius: 15; -fx-padding: 10;">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Summer 2026" textFill="WHITE">
                                                    <font><Font name="ArtifaktElement-Heavy" size="15.0" /></font>
                                                </Label>
                                                <Label text="01 Jun 2026  -  31 Aug 2026" textFill="#d3e2e7" />
                                                <Label text="Status: Finished | winners announced" textFill="#d3e2e7" />
                                            </children>
                                        </VBox>
                                        <Button mnemonicParsing="false" prefHeight="28.0" prefWidth="70.0"
                                                style="-fx-background-color: #5f86a6; -fx-background-radius: 12;"
                                                text="Open" textFill="WHITE" />
                                    </children>
                                </HBox>

                                <HBox alignment="CENTER_LEFT" spacing="14.0"
                                      style="-fx-background-color: #1d4052; -fx-background-radius: 15; -fx-padding: 10;">
                                    <children>
                                        <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Autumn 2026" textFill="WHITE">
                                                    <font><Font name="ArtifaktElement-Heavy" size="15.0" /></font>
                                                </Label>
                                                <Label text="01 Sep 2026  -  30 Nov 2026" textFill="#d3e2e7" />
                                                <Label text="Status: Finished | 6 tournaments" textFill="#d3e2e7" />
                                            </children>
                                        </VBox>
                                        <Button mnemonicParsing="false" prefHeight="28.0" prefWidth="70.0"
                                                style="-fx-background-color: #5f86a6; -fx-background-radius: 12;"
                                                text="Open" textFill="WHITE" />
                                    </children>
                                </HBox>
                            </children>
                            <effect>
                                <Blend />
                            </effect>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
</BorderPane>
