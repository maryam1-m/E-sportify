<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<TitledPane fx:controller="org.example.controller.SigninController"
            animated="false"
            maxHeight="-Infinity"
            maxWidth="-Infinity"
            minHeight="-Infinity"
            minWidth="-Infinity"
            prefHeight="400.0"
            prefWidth="600.0"
            text="E-Sportify"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1">

    <content>
        <AnchorPane minHeight="0.0"
                    minWidth="0.0"
                    prefHeight="180.0"
                    prefWidth="200.0">

            <children>

                <ImageView fitHeight="374.0"
                           fitWidth="600.0"
                           pickOnBounds="true">
                    <image>
                        <Image url="@images/signin.jpeg"/>
                    </image>
                </ImageView>

                <Rectangle arcHeight="30.0"
                           arcWidth="30.0"
                           fill="#e1e8ec"
                           height="268.0"
                           layoutX="318.0"
                           layoutY="44.0"
                           opacity="0.6"
                           stroke="#97c9c6"
                           strokeType="INSIDE"
                           width="267.0" />

                <Label layoutX="382.0"
                       layoutY="44.0"
                       prefHeight="18.0"
                       prefWidth="140.0"
                       style="-fx-text-fill: #1d677f;"
                       text="SIGN IN"
                       textAlignment="CENTER"
                       textFill="#47bfad">
                    <font>
                        <Font name="Century Schoolbook Bold" size="31.0" />
                    </font>
                </Label>

                <Label layoutX="324.0"
                       layoutY="97.0"
                       prefHeight="18.0"
                       prefWidth="256.0"
                       text="Welcome to E-Sportify, Sign in to access your Account"
                       textFill="#05394deb">
                    <font>
                        <Font name="Century" size="10.0" />
                    </font>
                </Label>

                <Label layoutX="372.0"
                       layoutY="126.0"
                       prefHeight="15.0"
                       prefWidth="35.0"
                       text="Email"
                       textFill="#04394d">
                    <font>
                        <Font name="Arial" size="10.0" />
                    </font>
                </Label>

                <TextField fx:id="emailField"
                           layoutX="372.0"
                           layoutY="143.0"
                           prefHeight="26.0"
                           prefWidth="197.0"
                           promptText="Email" />

                <Label layoutX="370.0"
                       layoutY="179.0"
                       text="Password"
                       textFill="#04394d">
                    <font>
                        <Font name="Arial" size="10.0" />
                    </font>
                </Label>

                <PasswordField fx:id="passwordField"
                               layoutX="371.0"
                               layoutY="192.0"
                               prefHeight="26.0"
                               prefWidth="198.0"
                               promptText="Password" />

                <TextField fx:id="visiblePasswordField"
                           layoutX="371.0"
                           layoutY="192.0"
                           prefHeight="26.0"
                           prefWidth="198.0"
                           promptText="Password"
                           visible="false"
                           managed="false" />

                <CheckBox fx:id="showPasswordCheckBox"
                          layoutX="366.0"
                          layoutY="230.0"
                          mnemonicParsing="false"
                          onAction="#togglePasswordVisibility"
                          text="Show Password"
                          textFill="#04394d">
                    <font>
                        <Font name="Arial" size="10.0" />
                    </font>
                </CheckBox>

                <Label layoutX="493.0"
                       layoutY="230.0"
                       prefHeight="15.0"
                       prefWidth="75.0"
                       text="Forget password"
                       textFill="#04394d"
                       underline="true">
                    <font>
                        <Font name="Arial" size="10.0" />
                    </font>
                </Label>

                <!-- BACK BUTTON -->
                <Button layoutX="336.0"
                        layoutY="269.0"
                        mnemonicParsing="false"
                        onAction="#goBack"
                        prefHeight="27.0"
                        prefWidth="100.0"
                        style="-fx-background-radius: 20; -fx-background-color: #0c7075;"
                        text="       Back"
                        textFill="WHITE">
                    <font>
                        <Font name="ArtifaktElement-Heavy" size="14.0" />
                    </font>
                </Button>

                <!-- LOGIN BUTTON -->
                <Button layoutX="469.0"
                        layoutY="269.0"
                        mnemonicParsing="false"
                        onAction="#handleLogin"
                        prefHeight="27.0"
                        prefWidth="98.0"
                        style="-fx-background-radius: 20; -fx-background-color: #0c7075;"
                        text="    log In"
                        textFill="WHITE">
                    <font>
                        <Font name="Artifakt Element Heavy Italic" size="14.0" />
                    </font>
                </Button>

                <ImageView fitHeight="17.0"
                           fitWidth="18.0"
                           layoutX="339.0"
                           layoutY="148.0"
                           pickOnBounds="true"
                           preserveRatio="true">
                    <image>
                        <Image url="@images/read.png" />
                    </image>
                </ImageView>

                <ImageView fitHeight="18.0"
                           fitWidth="15.0"
                           layoutX="340.0"
                           layoutY="198.0"
                           pickOnBounds="true"
                           preserveRatio="true">
                    <image>
                        <Image url="@images/locked-computer.png" />
                    </image>
                </ImageView>

                <ImageView fitHeight="24.0"
                           fitWidth="18.0"
                           layoutX="348.0"
                           layoutY="274.0"
                           pickOnBounds="true"
                           preserveRatio="true">
                    <image>
                        <Image url="@images/back.png" />
                    </image>
                </ImageView>

                <ImageView fitHeight="24.0"
                           fitWidth="18.0"
                           layoutX="476.0"
                           layoutY="273.0"
                           pickOnBounds="true"
                           preserveRatio="true">
                    <image>
                        <Image url="@images/log-out.png" />
                    </image>
                </ImageView>

            </children>
        </AnchorPane>
    </content>
</TitledPane>