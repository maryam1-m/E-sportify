<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Rectangle2D?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<BorderPane fx:controller="org.example.controller.TeamMemberController"
            maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="650.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1">

    <!-- ================= LEFT SIDEBAR ================= -->
    <left>
        <VBox spacing="20.0" style="-fx-background-color: #02182e;" BorderPane.alignment="CENTER">
            <children>

                <Label prefHeight="41.0" prefWidth="113.0" text="   E-Sportify" textFill="#d3e2e7">
                    <font>
                        <Font name="Century Schoolbook Bold" size="16.0" />
                    </font>
                </Label>

                <Button onAction="#goToDashboard" mnemonicParsing="false" prefHeight="26.0" prefWidth="126.0"
                        style="-fx-background-color: #02182e;" text="     Dashboard" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="22.0" fitWidth="16.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/progress.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToPlayers" mnemonicParsing="false" prefHeight="26.0" prefWidth="107.0"
                        style="-fx-background-color: #02182e;" text="        Players" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="17.0" fitWidth="39.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/soccer-player.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <!-- Current Page -->
                <Button mnemonicParsing="false" prefHeight="28.0" prefWidth="118.0"
                        style="-fx-background-color: #0b345c; -fx-background-radius: 12;"
                        text="      Teams" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="20.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/team.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToTournaments" mnemonicParsing="false" prefHeight="26.0" prefWidth="132.0"
                        style="-fx-background-color: #02182e;" text="     Tournments " textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="21.0" fitWidth="27.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/team-building.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToMatches" mnemonicParsing="false" prefHeight="30.0" prefWidth="110.0"
                        style="-fx-background-color: #02182e;" text="    Matches" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="26.0" fitWidth="26.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/match (1).png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToGames" mnemonicParsing="false" prefHeight="30.0" prefWidth="101.0"
                        style="-fx-background-color: #02182e;" text="    Games" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="32.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/game-controller.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToSeasons" mnemonicParsing="false" prefHeight="30.0" prefWidth="111.0"
                        style="-fx-background-color: #02182e;" text="     Seasons" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="32.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/calendar.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#logout" mnemonicParsing="false" prefHeight="30.0" prefWidth="111.0"
                        style="-fx-background-color: #02182e;" text="      LogOut" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="19.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/logout.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

            </children>

            <padding>
                <Insets left="20.0" />
            </padding>
        </VBox>
    </left>

    <!-- ================= CENTER CONTENT ================= -->
    <center>
        <VBox prefHeight="650.0" prefWidth="740.0" spacing="17.0"
              style="-fx-background-color: #02182e;">
            <padding>
                <Insets top="24.0" right="30.0" bottom="24.0" left="30.0" />
            </padding>

            <children>

                <!-- Header -->
                <HBox prefHeight="75.0" prefWidth="680.0" spacing="25.0">
                    <children>

                        <VBox prefHeight="75.0" prefWidth="430.0" spacing="5.0">
                            <children>
                                <Label text="Team Members" textFill="#d3e2e7">
                                    <font>
                                        <Font name="Century Schoolbook Bold" size="28.0" />
                                    </font>
                                </Label>

                                <Label text="Manage players inside each team and view their roles, games, and performance."
                                       textFill="#8197ac" wrapText="true">
                                    <font>
                                        <Font name="Century" size="13.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" prefHeight="75.0" prefWidth="210.0"
                              style="-fx-background-color: #022c50; -fx-background-radius: 25;">
                            <children>
                                <Label text="Total Members" textFill="#d3e2e7">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="16.0" />
                                    </font>
                                </Label>

                                <Label text="42" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="28.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                    </children>
                </HBox>

                <!-- Search + Add -->
                <HBox alignment="CENTER_LEFT" prefHeight="48.0" prefWidth="680.0" spacing="15.0">
                    <children>

                        <TextField fx:id="searchMemberField"
                                   prefHeight="38.0" prefWidth="430.0"
                                   promptText="Search team member..."
                                   style="-fx-background-color: #d3e2e7;
                                          -fx-background-radius: 20;
                                          -fx-text-fill: #02182e;
                                          -fx-prompt-text-fill: #5f86a6;
                                          -fx-padding: 0 15 0 15;" />

                        <Button onAction="#searchMember"
                                mnemonicParsing="false"
                                prefHeight="38.0" prefWidth="105.0"
                                text="Search"
                                textFill="WHITE"
                                style="-fx-background-color: #2b537e;
                                       -fx-background-radius: 20;">
                            <font>
                                <Font name="ArtifaktElement-Heavy" size="14.0" />
                            </font>
                        </Button>

                        <Button onAction="#addTeamMember"
                                mnemonicParsing="false"
                                prefHeight="38.0" prefWidth="120.0"
                                text="+ Add Member"
                                textFill="WHITE"
                                style="-fx-background-color: #5f86a6;
                                       -fx-background-radius: 20;">
                            <font>
                                <Font name="ArtifaktElement-Heavy" size="13.0" />
                            </font>
                        </Button>

                    </children>
                </HBox>

                <!-- Main Info Section -->
                <HBox prefHeight="170.0" prefWidth="680.0" spacing="20.0">
                    <children>

                        <!-- Team Card -->
                        <VBox alignment="CENTER" prefHeight="170.0" prefWidth="230.0"
                              style="-fx-background-color: #2b537e; -fx-background-radius: 30;">
                            <children>

                                <!-- هون بتحطي صورة الفريق أو صورة اللاعب -->
                                <ImageView fitHeight="90.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@images/team.png" />
                                    </image>
                                    <viewport>
                                        <Rectangle2D />
                                    </viewport>
                                </ImageView>

                                <Label text="Nexus Squad" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="19.0" />
                                    </font>
                                </Label>

                                <Label text="Selected Team" textFill="#d3e2e7">
                                    <font>
                                        <Font name="Century" size="12.0" />
                                    </font>
                                </Label>

                            </children>
                        </VBox>

                        <!-- Selected Member Details -->
                        <VBox prefHeight="170.0" prefWidth="430.0" spacing="9.0"
                              style="-fx-background-color: #022c50; -fx-background-radius: 30;">
                            <padding>
                                <Insets top="18.0" right="20.0" bottom="18.0" left="20.0" />
                            </padding>

                            <children>

                                <Label text="Selected Member Details" textFill="WHITE">
                                    <font>
                                        <Font name="Century Schoolbook Bold" size="22.0" />
                                    </font>
                                </Label>

                                <Line endX="365.0" opacity="0.25" stroke="#d3e2e7" />

                                <HBox spacing="25.0">
                                    <children>
                                        <Label text="Name: Maryam Abdoh" textFill="#d3e2e7">
                                            <font>
                                                <Font name="Century" size="13.0" />
                                            </font>
                                        </Label>

                                        <Label text="Role: Captain" textFill="#d3e2e7">
                                            <font>
                                                <Font name="Century" size="13.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>

                                <HBox spacing="25.0">
                                    <children>
                                        <Label text="Game: Valorant" textFill="#d3e2e7">
                                            <font>
                                                <Font name="Century" size="13.0" />
                                            </font>
                                        </Label>

                                        <Label text="Status: Active" textFill="#d3e2e7">
                                            <font>
                                                <Font name="Century" size="13.0" />
                                            </font>
                                        </Label>
                                    </children>
                                </HBox>

                                <HBox spacing="15.0">
                                    <children>

                                        <VBox alignment="CENTER" prefHeight="50.0" prefWidth="105.0"
                                              style="-fx-background-color: #1d4052; -fx-background-radius: 16;">
                                            <children>
                                                <Label text="Matches" textFill="#d3e2e7" />
                                                <Label text="18" textFill="WHITE">
                                                    <font>
                                                        <Font name="ArtifaktElement-Heavy" size="18.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </VBox>

                                        <VBox alignment="CENTER" prefHeight="50.0" prefWidth="105.0"
                                              style="-fx-background-color: #1d4052; -fx-background-radius: 16;">
                                            <children>
                                                <Label text="Wins" textFill="#d3e2e7" />
                                                <Label text="12" textFill="WHITE">
                                                    <font>
                                                        <Font name="ArtifaktElement-Heavy" size="18.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </VBox>

                                        <VBox alignment="CENTER" prefHeight="50.0" prefWidth="105.0"
                                              style="-fx-background-color: #1d4052; -fx-background-radius: 16;">
                                            <children>
                                                <Label text="Rating" textFill="#d3e2e7" />
                                                <Label text="4.8" textFill="WHITE">
                                                    <font>
                                                        <Font name="ArtifaktElement-Heavy" size="18.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </VBox>

                                    </children>
                                </HBox>

                            </children>
                        </VBox>

                    </children>
                </HBox>

                <!-- Members List -->
                <VBox prefHeight="280.0" prefWidth="680.0" spacing="8.0"
                      style="-fx-background-color: #022c50; -fx-background-radius: 25;">
                    <padding>
                        <Insets top="15.0" right="18.0" bottom="15.0" left="18.0" />
                    </padding>

                    <children>

                        <HBox prefHeight="35.0" prefWidth="640.0">
                            <children>
                                <Label prefWidth="150.0" text="Member Name" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="15.0" />
                                    </font>
                                </Label>

                                <Label prefWidth="120.0" text="Team" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="15.0" />
                                    </font>
                                </Label>

                                <Label prefWidth="120.0" text="Game" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="15.0" />
                                    </font>
                                </Label>

                                <Label prefWidth="95.0" text="Role" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="15.0" />
                                    </font>
                                </Label>

                                <Label prefWidth="80.0" text="Status" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="15.0" />
                                    </font>
                                </Label>

                                <Label prefWidth="80.0" text="Action" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="15.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>

                        <Line endX="640.0" opacity="0.30" stroke="#d3e2e7" />

                        <!-- Row 1 -->
                        <HBox alignment="CENTER_LEFT" prefHeight="38.0" prefWidth="640.0">
                            <children>
                                <Label prefWidth="150.0" text="Maryam Abdoh" textFill="#d3e2e7" />
                                <Label prefWidth="120.0" text="Nexus Squad" textFill="#d3e2e7" />
                                <Label prefWidth="120.0" text="Valorant" textFill="#d3e2e7" />
                                <Label prefWidth="95.0" text="Captain" textFill="#d3e2e7" />
                                <Label prefWidth="80.0" text="Active" textFill="#d3e2e7" />

                                <Button onAction="#viewMemberDetails"
                                        mnemonicParsing="false"
                                        prefHeight="26.0" prefWidth="70.0"
                                        text="View"
                                        textFill="WHITE"
                                        style="-fx-background-color: #5f86a6; -fx-background-radius: 13;" />
                            </children>
                        </HBox>

                        <Line endX="640.0" opacity="0.18" stroke="#d3e2e7" />

                        <!-- Row 2 -->
                        <HBox alignment="CENTER_LEFT" prefHeight="38.0" prefWidth="640.0">
                            <children>
                                <Label prefWidth="150.0" text="Ahmad Ali" textFill="#d3e2e7" />
                                <Label prefWidth="120.0" text="Nexus Squad" textFill="#d3e2e7" />
                                <Label prefWidth="120.0" text="Valorant" textFill="#d3e2e7" />
                                <Label prefWidth="95.0" text="Player" textFill="#d3e2e7" />
                                <Label prefWidth="80.0" text="Active" textFill="#d3e2e7" />

                                <Button onAction="#viewMemberDetails"
                                        mnemonicParsing="false"
                                        prefHeight="26.0" prefWidth="70.0"
                                        text="View"
                                        textFill="WHITE"
                                        style="-fx-background-color: #5f86a6; -fx-background-radius: 13;" />
                            </children>
                        </HBox>

                        <Line endX="640.0" opacity="0.18" stroke="#d3e2e7" />

                        <!-- Row 3 -->
                        <HBox alignment="CENTER_LEFT" prefHeight="38.0" prefWidth="640.0">
                            <children>
                                <Label prefWidth="150.0" text="Yamen Marie" textFill="#d3e2e7" />
                                <Label prefWidth="120.0" text="Iron Brokers" textFill="#d3e2e7" />
                                <Label prefWidth="120.0" text="FIFA 25" textFill="#d3e2e7" />
                                <Label prefWidth="95.0" text="Player" textFill="#d3e2e7" />
                                <Label prefWidth="80.0" text="Active" textFill="#d3e2e7" />

                                <Button onAction="#viewMemberDetails"
                                        mnemonicParsing="false"
                                        prefHeight="26.0" prefWidth="70.0"
                                        text="View"
                                        textFill="WHITE"
                                        style="-fx-background-color: #5f86a6; -fx-background-radius: 13;" />
                            </children>
                        </HBox>

                        <Line endX="640.0" opacity="0.18" stroke="#d3e2e7" />

                        <!-- Row 4 -->
                        <HBox alignment="CENTER_LEFT" prefHeight="38.0" prefWidth="640.0">
                            <children>
                                <Label prefWidth="150.0" text="Jana Salahat" textFill="#d3e2e7" />
                                <Label prefWidth="120.0" text="The Titans" textFill="#d3e2e7" />
                                <Label prefWidth="120.0" text="Rocket League" textFill="#d3e2e7" />
                                <Label prefWidth="95.0" text="Substitute" textFill="#d3e2e7" />
                                <Label prefWidth="80.0" text="Pending" textFill="#d3e2e7" />

                                <Button onAction="#viewMemberDetails"
                                        mnemonicParsing="false"
                                        prefHeight="26.0" prefWidth="70.0"
                                        text="View"
                                        textFill="WHITE"
                                        style="-fx-background-color: #5f86a6; -fx-background-radius: 13;" />
                            </children>
                        </HBox>

                    </children>
                </VBox>

            </children>
        </VBox>
    </center>

</BorderPane>