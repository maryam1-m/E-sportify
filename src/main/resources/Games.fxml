<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Rectangle2D?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<BorderPane fx:controller="org.example.controller.GamesController"
            maxHeight="-Infinity" maxWidth="-Infinity"
            minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="650.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1">

    <!-- ================= LEFT SIDEBAR ================= -->
    <left>
        <VBox spacing="20.0" style="-fx-background-color: #02182e;" BorderPane.alignment="CENTER">
            <children>

                <Label prefHeight="41.0" prefWidth="113.0" text="   E-Sportify" textFill="#d3e2e7">
                    <font>
                        <Font name="Century Schoolbook Bold" size="16.0" />
                    </font>
                </Label>

                <Button onAction="#goToDashboard"
                        mnemonicParsing="false"
                        prefHeight="26.0"
                        prefWidth="126.0"
                        style="-fx-background-color: #02182e;"
                        text="     Dashboard"
                        textFill="WHITE">

                    <graphic>
                        <ImageView fitHeight="22.0"
                                   fitWidth="16.0"
                                   pickOnBounds="true"
                                   preserveRatio="true">
                            <image>
                                <Image url="@images/progress.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToPlayers" mnemonicParsing="false" prefHeight="26.0" prefWidth="107.0"
                        style="-fx-background-color: #02182e;" text="        Players" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="17.0" fitWidth="39.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/soccer-player.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToTeams" mnemonicParsing="false" prefHeight="28.0" prefWidth="106.0"
                        style="-fx-background-color: #02182e;" text="         Teams" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="20.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/team.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToTournaments" mnemonicParsing="false" prefHeight="26.0" prefWidth="132.0"
                        style="-fx-background-color: #02182e;" text="     Tournments " textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="21.0" fitWidth="27.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/team-building.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToMatches" mnemonicParsing="false" prefHeight="30.0" prefWidth="110.0"
                        style="-fx-background-color: #02182e;" text="    Matches" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="26.0" fitWidth="26.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/match (1).png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <!-- Current Page -->
                <Button mnemonicParsing="false" onAction="#goToGames" prefHeight="30.0" prefWidth="101.0"
                        style="-fx-background-color: #0b345c; -fx-background-radius: 12;"
                        text="    Games" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="32.0" fitWidth="28.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/game-controller.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#goToSeasons" mnemonicParsing="false" prefHeight="30.0" prefWidth="111.0"
                        style="-fx-background-color: #02182e;" text="     Seasons" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="32.0" fitWidth="22.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/calendar.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

                <Button onAction="#logout" mnemonicParsing="false" prefHeight="30.0" prefWidth="111.0"
                        style="-fx-background-color: #02182e;" text="      LogOut" textFill="WHITE">
                    <graphic>
                        <ImageView fitHeight="19.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@images/logout.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>

            </children>

            <padding>
                <Insets left="20.0" />
            </padding>
        </VBox>
    </left>

    <!-- ================= CENTER CONTENT ================= -->
    <center>
        <VBox prefHeight="650.0" prefWidth="740.0" spacing="18.0"
              style="-fx-background-color: #02182e;">
            <padding>
                <Insets top="25.0" right="30.0" bottom="25.0" left="30.0" />
            </padding>

            <children>

                <!-- Header -->
                <HBox prefHeight="70.0" prefWidth="680.0" spacing="25.0">
                    <children>

                        <VBox prefHeight="70.0" prefWidth="420.0" spacing="5.0">
                            <children>
                                <Label text="Games Library" textFill="#d3e2e7">
                                    <font>
                                        <Font name="Century Schoolbook Bold" size="28.0" />
                                    </font>
                                </Label>

                                <Label text="Choose your favorite game and explore its tournaments, teams, and matches."
                                       textFill="#8197ac">
                                    <font>
                                        <Font name="Century" size="13.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <VBox alignment="CENTER" prefHeight="70.0" prefWidth="220.0"
                              style="-fx-background-color: #022c50; -fx-background-radius: 25;">
                            <children>
                                <Label text="Available Games" textFill="#d3e2e7">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="16.0" />
                                    </font>
                                </Label>

                                <Label fx:id="availableGamesCountLabel" text="0" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="28.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                    </children>
                </HBox>

                <!-- Search Bar -->
                <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="680.0" spacing="15.0">
                    <children>

                        <TextField fx:id="searchGameField"
                                   prefHeight="38.0" prefWidth="500.0"
                                   promptText="Search for a game..."
                                   style="-fx-background-color: #d3e2e7;
                                          -fx-background-radius: 20;
                                          -fx-text-fill: #02182e;
                                          -fx-prompt-text-fill: #5f86a6;
                                          -fx-padding: 0 15 0 15;" />

                        <Button onAction="#searchGame"
                                mnemonicParsing="false"
                                prefHeight="38.0" prefWidth="140.0"
                                text="Search"
                                textFill="WHITE"
                                style="-fx-background-color: #2b537e;
                                       -fx-background-radius: 20;">
                            <font>
                                <Font name="ArtifaktElement-Heavy" size="14.0" />
                            </font>
                        </Button>

                    </children>
                </HBox>

                <!-- Featured Game Section -->
                <HBox prefHeight="170.0" prefWidth="680.0" spacing="20.0">
                    <children>

                        <VBox alignment="CENTER" prefHeight="170.0" prefWidth="230.0"
                              style="-fx-background-color: #2b537e; -fx-background-radius: 30;">
                            <children>

                                <ImageView fitHeight="95.0" fitWidth="120.0" pickOnBounds="true" preserveRatio="true">
                                    <image>
                                        <Image url="@images/game-controller.png" />
                                    </image>
                                    <viewport>
                                        <Rectangle2D />
                                    </viewport>
                                </ImageView>

                                <Label fx:id="featuredGameSmallTitleLabel" text="Featured Game" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="18.0" />
                                    </font>
                                </Label>

                            </children>
                        </VBox>

                        <VBox prefHeight="170.0" prefWidth="430.0" spacing="10.0"
                              style="-fx-background-color: #022c50; -fx-background-radius: 30;">
                            <padding>
                                <Insets top="18.0" right="20.0" bottom="18.0" left="20.0" />
                            </padding>

                            <children>
                                <Label fx:id="featuredGameTitleLabel" text="Game Name" textFill="WHITE">
                                    <font>
                                        <Font name="Century Schoolbook Bold" size="25.0" />
                                    </font>
                                </Label>

                                <Label fx:id="featuredGameDescriptionLabel"
                                       text="Game details will appear here from the database."
                                       wrapText="true" textFill="#d3e2e7">
                                    <font>
                                        <Font name="Century" size="13.0" />
                                    </font>
                                </Label>

                                <HBox spacing="15.0">
                                    <children>
                                        <VBox alignment="CENTER" prefHeight="55.0" prefWidth="100.0"
                                              style="-fx-background-color: #1d4052; -fx-background-radius: 18;">
                                            <children>
                                                <Label text="Teams" textFill="#d3e2e7" />
                                                <Label fx:id="featuredTeamsCountLabel" text="0" textFill="WHITE">
                                                    <font>
                                                        <Font name="ArtifaktElement-Heavy" size="18.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </VBox>

                                        <VBox alignment="CENTER" prefHeight="55.0" prefWidth="100.0"
                                              style="-fx-background-color: #1d4052; -fx-background-radius: 18;">
                                            <children>
                                                <Label text="Matches" textFill="#d3e2e7" />
                                                <Label fx:id="featuredMatchesCountLabel" text="0" textFill="WHITE">
                                                    <font>
                                                        <Font name="ArtifaktElement-Heavy" size="18.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </VBox>

                                        <VBox alignment="CENTER" prefHeight="55.0" prefWidth="120.0"
                                              style="-fx-background-color: #1d4052; -fx-background-radius: 18;">
                                            <children>
                                                <Label text="Tournaments" textFill="#d3e2e7" />
                                                <Label fx:id="featuredTournamentsCountLabel" text="0" textFill="WHITE">
                                                    <font>
                                                        <Font name="ArtifaktElement-Heavy" size="18.0" />
                                                    </font>
                                                </Label>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>

                                <Button onAction="#joinFeaturedGame"
                                        mnemonicParsing="false"
                                        prefHeight="30.0" prefWidth="160.0"
                                        text="Join Game"
                                        textFill="WHITE"
                                        style="-fx-background-color: #02182e; -fx-background-radius: 15;">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="13.0" />
                                    </font>
                                </Button>

                            </children>
                        </VBox>

                    </children>
                </HBox>

                <!-- Games Cards -->
                <HBox prefHeight="235.0" prefWidth="680.0" spacing="20.0">
                    <children>

                        <!-- Game Card 1 -->
                        <VBox prefHeight="230.0" prefWidth="210.0"
                              style="-fx-background-color: #5f86a6; -fx-background-radius: 25;">
                            <padding>
                                <Insets top="15.0" right="15.0" bottom="15.0" left="15.0" />
                            </padding>

                            <children>
                                <VBox alignment="CENTER" prefHeight="90.0" prefWidth="180.0">
                                    <children>
                                        <ImageView fitHeight="75.0" fitWidth="85.0" pickOnBounds="true" preserveRatio="true">
                                            <image>
                                                <Image url="@images/game-controller.png" />
                                            </image>
                                        </ImageView>
                                    </children>
                                </VBox>

                                <Label fx:id="game1TitleLabel" text="Game 1" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="19.0" />
                                    </font>
                                </Label>

                                <Line endX="155.0" opacity="0.35" stroke="#d3e2e7" />

                                <Label fx:id="game1CategoryLabel" text="Category: -" textFill="WHITE" />
                                <Label fx:id="game1PriceLabel" text="Price: -" textFill="WHITE" />
                                <Label fx:id="game1DeveloperLabel" text="Developer: -" textFill="WHITE" />

                                <Button onAction="#viewGame1Details"
                                        mnemonicParsing="false"
                                        prefHeight="30.0" prefWidth="175.0"
                                        text="View Details"
                                        textFill="WHITE"
                                        style="-fx-background-color: #02182e; -fx-background-radius: 15;">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="13.0" />
                                    </font>
                                </Button>
                                <Button onAction="#joinGame1"
                                        mnemonicParsing="false"
                                        prefHeight="28.0" prefWidth="175.0"
                                        text="Join Game"
                                        textFill="WHITE"
                                        style="-fx-background-color: #02182e; -fx-background-radius: 15;">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="12.0" />
                                    </font>
                                </Button>
                            </children>
                        </VBox>

                        <!-- Game Card 2 -->
                        <VBox prefHeight="230.0" prefWidth="210.0"
                              style="-fx-background-color: #2b537e; -fx-background-radius: 25;">
                            <padding>
                                <Insets top="15.0" right="15.0" bottom="15.0" left="15.0" />
                            </padding>

                            <children>
                                <VBox alignment="CENTER" prefHeight="90.0" prefWidth="180.0">
                                    <children>
                                        <ImageView fitHeight="75.0" fitWidth="85.0" pickOnBounds="true" preserveRatio="true">
                                            <image>
                                                <Image url="@images/game-controller.png" />
                                            </image>
                                        </ImageView>
                                    </children>
                                </VBox>

                                <Label fx:id="game2TitleLabel" text="Game 2" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="19.0" />
                                    </font>
                                </Label>

                                <Line endX="155.0" opacity="0.35" stroke="#d3e2e7" />

                                <Label fx:id="game2CategoryLabel" text="Category: -" textFill="WHITE" />
                                <Label fx:id="game2PriceLabel" text="Price: -" textFill="WHITE" />
                                <Label fx:id="game2DeveloperLabel" text="Developer: -" textFill="WHITE" />

                                <Button onAction="#viewGame2Details"
                                        mnemonicParsing="false"
                                        prefHeight="30.0" prefWidth="175.0"
                                        text="View Details"
                                        textFill="WHITE"
                                        style="-fx-background-color: #02182e; -fx-background-radius: 15;">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="13.0" />
                                    </font>
                                </Button>
                                <Button onAction="#joinGame2"
                                        mnemonicParsing="false"
                                        prefHeight="28.0" prefWidth="175.0"
                                        text="Join Game"
                                        textFill="WHITE"
                                        style="-fx-background-color: #02182e; -fx-background-radius: 15;">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="12.0" />
                                    </font>
                                </Button>
                            </children>
                        </VBox>

                        <!-- Game Card 3 -->
                        <VBox prefHeight="230.0" prefWidth="210.0"
                              style="-fx-background-color: #8197ac; -fx-background-radius: 25;">
                            <padding>
                                <Insets top="15.0" right="15.0" bottom="15.0" left="15.0" />
                            </padding>

                            <children>
                                <VBox alignment="CENTER" prefHeight="90.0" prefWidth="180.0">
                                    <children>
                                        <ImageView fitHeight="75.0" fitWidth="85.0" pickOnBounds="true" preserveRatio="true">
                                            <image>
                                                <Image url="@images/game-controller.png" />
                                            </image>
                                        </ImageView>
                                    </children>
                                </VBox>

                                <Label fx:id="game3TitleLabel" text="Game 3" textFill="WHITE">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="18.0" />
                                    </font>
                                </Label>

                                <Line endX="155.0" opacity="0.35" stroke="#d3e2e7" />

                                <Label fx:id="game3CategoryLabel" text="Category: -" textFill="WHITE" />
                                <Label fx:id="game3PriceLabel" text="Price: -" textFill="WHITE" />
                                <Label fx:id="game3DeveloperLabel" text="Developer: -" textFill="WHITE" />

                                <Button onAction="#viewGame3Details"
                                        mnemonicParsing="false"
                                        prefHeight="30.0" prefWidth="175.0"
                                        text="View Details"
                                        textFill="WHITE"
                                        style="-fx-background-color: #02182e; -fx-background-radius: 15;">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="13.0" />
                                    </font>
                                </Button>
                                <Button onAction="#joinGame3"
                                        mnemonicParsing="false"
                                        prefHeight="28.0" prefWidth="175.0"
                                        text="Join Game"
                                        textFill="WHITE"
                                        style="-fx-background-color: #02182e; -fx-background-radius: 15;">
                                    <font>
                                        <Font name="ArtifaktElement-Heavy" size="12.0" />
                                    </font>
                                </Button>
                            </children>
                        </VBox>

                    </children>
                </HBox>

            </children>
        </VBox>
    </center>

</BorderPane>